<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:2.3" version="2.3" srcLang="en" trgLang="pl">
  <file id="validation">
    <unit id="validation.required">
      <segment>
        <source>The field is required.</source>
        <target>Pole jest wymagane.</target>
      </segment>
    </unit>
    <unit id="validation.min">
      <segment>
        <source>The field must be at least :value characters long.</source>
        <target>Pole musi mieć co najmniej :value znak/i/ów.</target>
      </segment>
    </unit>
    <unit id="validation.max">
      <segment>
        <source>The field cannot exceed :value characters long.</source>
        <target>Pole nie może przekraczać :value znaków.</target>
      </segment>
    </unit>
    <unit id="validation.string">
      <segment>
        <source>The field must be a string.</source>
        <target>Pole musi być ciągiem tekstowym.</target>
      </segment>
    </unit>
    <unit id="validation.email">
      <segment>
        <source>Invalid email address.</source>
        <target>Nieprawidłowy adres e-mail.</target>
      </segment>
    </unit>
    <unit id="validation.url">
      <segment>
        <source>Field must be a valid URL.</source>
        <target>Pole musi być prawidłowym adresem URL.</target>
      </segment>
    </unit>
    <unit id="validation.phone">
      <segment>
        <source>Field must be a valid phone number.</source>
        <target>Pole musi zawierać prawidłowy numer telefonu.</target>
      </segment>
    </unit>
    <unit id="validation.letters_spaces">
      <segment>
        <source>Field can only contain letters, spaces, and dashes.</source>
        <target>Pole może zawierać tylko litery, spacje i myślniki.</target>
      </segment>
    </unit>
    <unit id="validation.password">
      <segment>
        <source>Field must meet the password strength requirements.</source>
        <target>Pole musi spełniać wymagania dotyczące siły hasła.</target>
      </segment>
    </unit>
    <unit id="validation.confirmed">
      <segment>
        <source>Field confirmation does not match.</source>
        <target>Pole potwierdzenia nie pasuje.</target>
      </segment>
    </unit>
    <unit id="validation.regex">
      <segment>
        <source>The field contains invalid characters.</source>
        <target>Pole zawiera niedozwolone znaki.</target>
      </segment>
    </unit>
    <unit id="validation.csrf">
      <segment>
        <source>Invalid security token. Please refresh the page and try again.</source>
        <target>Nieprawidłowy token bezpieczeństwa. Odśwież stronę i spróbuj ponownie.</target>
      </segment>
    </unit>

    <unit id="validation.slug_required">
        <segment>
            <source>Slug is required.</source>
            <target>Slug jest wymagany.</target>
        </segment>
    </unit>

    <unit id="validation.slug_invalid_chars">
        <segment>
            <source>Allowed characters: lowercase letters, digits, "-", "." and "/".</source>
            <target>Dozwolone: małe litery, cyfry, "-", "." i "/".</target>
        </segment>
    </unit>

    <unit id="validation.slug_double_slash">
        <segment>
            <source>Double "/" is not allowed.</source>
            <target>Nie można używać podwójnych "/".</target>
        </segment>
    </unit>

    <unit id="validation.slug_start_end_slash">
        <segment>
            <source>The slug cannot start or end with "/".</source>
            <target>Nie może zaczynać ani kończyć się "/".</target>
        </segment>
    </unit>

    <unit id="validation.slug_invalid_segment">
        <segment>
            <source>Invalid segment: :value.</source>
            <target>Niepoprawny segment: :value.</target>
        </segment>
    </unit>

    <unit id="validation.keywords_required">
        <segment>
            <source>Keywords field is required.</source>
            <target>Pole słowa kluczowe jest wymagane.</target>
        </segment>
    </unit>

    <unit id="validation.description_required">
        <segment>
            <source>Description field is required.</source>
            <target>Pole opisu jest wymagane.</target>
        </segment>
    </unit>

    <unit id="validation.title_required">
        <segment>
            <source>Title field is required.</source>
            <target>Pole tytułu jest wymagane.</target>
        </segment>
    </unit>

    <unit id="validation.title_length">
        <segment>
            <source>Title must contain between :min and :max characters.</source>
            <target>Tytuł musi zawierać od :min do :max znaków.</target>
        </segment>
    </unit>

    <unit id="validation.content_required">
        <segment>
            <source>Content field is required.</source>
            <target>Pole zawartości jest wymagane.</target>
        </segment>
    </unit>

    <unit id="validation.content_min">
        <segment>
            <source>Content must contain at least :value characters.</source>
            <target>Zawartość musi zawierać minimum :value znaków.</target>
        </segment>
    </unit>

  </file>
</xliff>
