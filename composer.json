{
    "name": "designbymalina/dbmplatform",
    "description": "DBM Platform - Modular application platform based on DBM Framework",
    "keywords": ["php", "cms", "platform", "modular", "modular-monolith", "application", "framework"],
    "homepage": "https://dbm.org.pl",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Artur Malinowski",
            "role": "developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "designbymalina/dbmframework": "~6.1",
        "doctrine/dbal": "^4.3",
        "phpmailer/phpmailer": "^6.6",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.59",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Mod\\": "modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "fix": "php-cs-fixer fix"
    },
    "support": {
	    "source": "https://github.com/designbymalina/dbmplatform"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
